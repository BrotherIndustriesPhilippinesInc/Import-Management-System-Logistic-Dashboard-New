@model LogisticDashboard.Core.ImportPICInformation

@{
    ViewData["Title"] = "Create PIC Info";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0" style="max-width: 600px; margin: auto;">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-person-plus"></i> Add Import PIC Information</h4>
        </div>
        <div class="card-body p-4">
            <form asp-controller="ImportPICInformations" asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="ModeOfShipment" class="form-label fw-bold">Mode of Shipment</label>
                    <select asp-for="ModeOfShipment" class="form-select">
                        <option value="">-- Select Mode --</option>
                        <option value="Sea">Sea</option>
                        <option value="Air">Air</option>
                        <option value="Courier">Courier</option>
                    </select>
                    <span asp-validation-for="ModeOfShipment" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Supplier" class="form-label fw-bold">Supplier</label>
                    <input asp-for="Supplier" class="form-control" placeholder="Enter supplier name" />
                    <span asp-validation-for="Supplier" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="ShippingMainPICStaff" class="form-label fw-bold">Main PIC Staff</label>
                        <input asp-for="ShippingMainPICStaff" class="form-control" placeholder="Main contact" />
                        <span asp-validation-for="ShippingMainPICStaff" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="ShippingSubPICStaff" class="form-label fw-bold">Sub PIC Staff</label>
                        <input asp-for="ShippingSubPICStaff" class="form-control" placeholder="Backup contact" />
                        <span asp-validation-for="ShippingSubPICStaff" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Supervisor" class="form-label fw-bold">Supervisor</label>
                    <input asp-for="Supervisor" class="form-control" placeholder="Supervisor name" />
                    <span asp-validation-for="Supervisor" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Save Information</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}